# LLM proxy
LLM_PROXY_KEY=sk-...
LLM_PROXY_URL=https://llm.devopsinstitute.id

# Telegram
TELEGRAM_BOT_TOKEN=...

# Grafana
GRAFANA_URL=https://grafana.<your-group>.devopsinstitute.id
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_...

# Bitbucket — use your account EMAIL, not username
BITBUCKET_USER=your@email.com
BITBUCKET_APP_PASSWORD=...
BITBUCKET_WORKSPACE=academytools

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-this        # required — bot refuses to start without this
ADMIN_PORT=8080

# Optional — Telegram thread ID for audit write-action notifications
# AUDIT_THREAD_ID=4
